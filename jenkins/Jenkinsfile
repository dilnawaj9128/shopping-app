pipeline {
    agent any
    
    options {
        disableConcurrentBuilds()
    }

    environment {
        DOCKER_USER = 'dilnawaz9128'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }
    stages {

        stage('Checkout') {
            steps {
                deleteDir()
                git branch: 'main', url: 'https://github.com/dilnawaj9128/shopping-app.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool 'SonarScanner'

                    withSonarQubeEnv('SonarQube') {
                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=shopping-app \
                        -Dsonar.projectName=shopping-app \
                        -Dsonar.sources=.
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Backend') {
            steps {
                sh "docker build -t shopping-app-backend:${IMAGE_TAG} ./backend"
            }
        }

        stage('Build Frontend') {
            steps {
                sh "docker build -t shopping-app-frontend:${IMAGE_TAG} ./frontend"
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                trivy image --exit-code 1 --severity CRITICAL --no-progress shopping-app-backend:latest
                trivy image --exit-code 1 --severity CRITICAL --no-progress shopping-app-frontend:latest
                '''
            }
        }
        stage('Push to Docker Hub') {
            steps {
                echo "Pushing images to Docker Hub"
                withCredentials([usernamePassword(
                    credentialsId: 'dockerHubCred',
                    passwordVariable: 'dockerHubPass',
                    usernameVariable: 'dockerHubUser')]) {
                    sh "docker login -u ${env.dockerHubUser} -p ${env.dockerHubPass}"

                    // Build number tag push
                    sh "docker image tag shopping-app-backend:${IMAGE_TAG} ${env.dockerHubUser}/shopflow-backend:${IMAGE_TAG}"
                    sh "docker image tag shopping-app-frontend:${IMAGE_TAG} ${env.dockerHubUser}/shopflow-frontend:${IMAGE_TAG}"
                    sh "docker push ${env.dockerHubUser}/shopflow-backend:${IMAGE_TAG}"
                    sh "docker push ${env.dockerHubUser}/shopflow-frontend:${IMAGE_TAG}"

                    // Latest tag bhi push karo
                    sh "docker image tag shopping-app-backend:${IMAGE_TAG} ${env.dockerHubUser}/shopflow-backend:latest"
                    sh "docker image tag shopping-app-frontend:${IMAGE_TAG} ${env.dockerHubUser}/shopflow-frontend:latest"
                    sh "docker push ${env.dockerHubUser}/shopflow-backend:latest"
                    sh "docker push ${env.dockerHubUser}/shopflow-frontend:latest"

                    sh "docker logout"
                }
                echo "mages pushed successfully"
            }
        }
        stage("Update K8s Manifests") {
            steps {
                echo "Updating image tags in K8s manifests"
                withCredentials([usernamePassword(
                    credentialsId: 'github-creds',
                    passwordVariable: 'GIT_PASS',
                    usernameVariable: 'GIT_USER')]) {
                    sh """
                        # Update image tags
                        sed -i "s|image: ${DOCKER_USER}/shopflow-backend:.*|image: ${DOCKER_USER}/shopflow-backend:${IMAGE_TAG}|g" k8s/backend.yml
                        sed -i "s|image: ${DOCKER_USER}/shopflow-frontend:.*|image: ${DOCKER_USER}/shopflow-frontend:${IMAGE_TAG}|g" k8s/frontend.yml

                        # Git config
                        git config user.email "jenkins@shopflow.in"
                        git config user.name "Jenkins CI"

                        # Commit aur push
                        git add k8s/backend.yml k8s/frontend.yml
                        git commit -m "ci: update image tag to ${IMAGE_TAG} [skip ci]" || echo "Nothing to commit"
                        git push https://${GIT_USER}:${GIT_PASS}@github.com/dilnawaj9128/shopping-app.git main
                    """
                }
                echo "k8s manifests updated"
            }
        }
        
        stage("Wait for ArgoCD Deployment") {
            steps {
                echo "Waiting for ArgoCD auto-sync deployment"

                withCredentials([
                    string(credentialsId: 'argocd-token', variable: 'ARGOCD_TOKEN')
                ]) {
                    sh '''
                        argocd app wait shopflow \
                            --server 172.19.0.2:31618 \
                            --auth-token "$ARGOCD_TOKEN" \
                            --plaintext \
                            --sync \
                            --health \
                            --timeout 200
                    '''
                }

                echo "ArgoCD Application is Synced and Healthy"
            }
        }
        stage('Smoke Test') {
            steps {
                echo 'Testing if backend is running'
                sh '''
                    kubectl run smoke-test \
                    --rm -i \
                    --restart=Never \
                    --image=curlimages/curl \
                    -n shopflow \
                    -- curl -f http://backend:5000/health
                '''
            }
        }
    }
}
