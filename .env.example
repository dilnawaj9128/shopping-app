# ═══════════════════════════════════════════════════════
#   ShopFlow — Environment Variables Template
#   Copy this to .env and fill in YOUR values
#   NEVER commit .env to Git!
# ═══════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────
NODE_ENV=production

# ── Ports (optional — defaults shown) ───────────────────
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=5000
MONGO_HOST_PORT=27017

# ── MongoDB credentials ──────────────────────────────────
# Use a strong unique password — no special chars that break URI
MONGO_ROOT_USER=shopflow_admin
MONGO_ROOT_PASS=CHANGE_ME_STRONG_PASSWORD

# ── JWT Secret ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RUN_THE_COMMAND_ABOVE

# ── Seed user credentials (only needed first run) ────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASS=CHANGE_ME_ADMIN_PASS
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_PASS=CHANGE_ME_USER_PASS

# ── Frontend URL for CORS ────────────────────────────────
FRONTEND_URL=http://localhost:3000
